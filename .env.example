# ==================== 应用 ====================
APP_NAME=AutoContentPlatform
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-in-production-please

# ==================== 数据库 (PostgreSQL) ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=acp_user
DB_PASSWORD=acp_password
DB_NAME=auto_content_platform

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== MinIO (对象存储) ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=auto-content-platform
MINIO_SECURE=false

# ==================== Playwright ====================
PLAYWRIGHT_CDP_URL=http://localhost:9222
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MODE=playwright

# ==================== AI 模型 ====================
# 选项: deepseek / qwen / openai
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 通义千问
QWEN_API_KEY=your-qwen-api-key-here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# ==================== AI 图片生成 ====================
# 选项: seedream / tongyi-wanxiang
IMAGE_GEN_PROVIDER=seedream
IMAGE_GEN_API_KEY=your-image-gen-api-key-here

# ==================== 代理 IP ====================
PROXY_ENABLED=false
PROXY_PROVIDER=
PROXY_API_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
